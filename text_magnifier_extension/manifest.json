{
  "manifest_version": 3,
  "name": "Text Magnifier",
  "description": "Magnify selected text and focused text-field content on web pages.",
  "version": "0.2.0",
  "permissions": [
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Text Magnifier",
    "default_popup": "popup.html"
  },
  "commands": {
    "toggle-magnifier": {
      "suggested_key": {
        "default": "Alt+Shift+M",
        "mac": "Alt+Shift+M"
      },
      "description": "Toggle text magnifier on the current tab"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
